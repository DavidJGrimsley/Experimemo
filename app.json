{
  "expo": {
    "name": "Experimemo",
    "slug": "experimemo",
    "version": "1.0.0",
    "scheme": "experimemo",
    "platforms": ["ios", "android"],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/Yellowtail-Regular.ttf"]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#ffffff",
          "imageWidth": 200,
          "dark": {
            "image": "./assets/splash-dark.png",
            "backgroundColor": "#09090b",
            "imageWidth": 200
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos so you can attach experiment images.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera so you can capture experiment photos later.",
          "microphonePermission": false
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-navigation-bar",
        {
          "style": "dark",
          "enforceContrast": false
        }
      ],
      "expo-system-ui"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mrdj2u.experimemo",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "mrdj2u.experimemo",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "backgroundColor": "#f1f0f8"
    },
    "backgroundColor": "#f1f0f8",
    "androidStatusBar": {
      "backgroundColor": "#f1f0f8",
      "barStyle": "dark-content",
      "translucent": false
    },
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "enforceContrast": false,
        "style": "dark"
      },
      "eas": {
        "projectId": "42ce5672-ed79-4d7c-878c-ad49f7cce353"
      }
    },
    "owner": "mrdj2u"
  }
}
