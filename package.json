{
  "name": "experimemo",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "ios": "expo start --ios",
    "start": "expo start",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:prod": "node -e \"console.log('Native-only app: running local release-readiness checks instead of a web export.')\" && npm run typecheck && npm run expo-doctor",
    "mds:continue": "npx mds continue",
    "mds:doctor": "npx mds doctor",
    "mds:doctor:ci": "npx mds doctor --ci",
    "stylist:sync:android": "node ./scripts/stylist-sync-android.mjs",
    "mds:eject": "npx mds eject .",
    "mds:eject:exposition": "npx mds eject exposition .",
    "mds:eject:stylist": "npx mds eject stylist .",
    "free-port": "npx mds free-port",
    "clear-expo-start": "npx mds clear-expo-start",
    "expo-install-fix": "npx expo install --fix",
    "expo-doctor": "npx expo-doctor",
    "post-create-check": "npx expo install --fix && npx expo-doctor",
    "ci:verify": "npx mds doctor --ci",
    "test": "npm run lint && npm run typecheck",
    "patch:nativewind-metro": "node ./scripts/patch-nativewind-metro.cjs",
    "prestart": "node ./scripts/patch-nativewind-metro.cjs",
    "preandroid": "node ./scripts/patch-nativewind-metro.cjs",
    "preweb": "node ./scripts/patch-nativewind-metro.cjs",
    "postinstall": "node ./scripts/patch-nativewind-metro.cjs"
  },
  "dependencies": {
    "@expo/log-box": "^56.0.12",
    "@expo/react-native-action-sheet": "^4.1.1",
    "@expo/ui": "~56.0.14",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/slider": "5.2.0",
    "@react-native-picker/picker": "2.11.4",
    "@rn-primitives/avatar": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@shopify/flash-list": "2.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "expo": "^56.0.12",
    "expo-constants": "~56.0.15",
    "expo-dev-client": "~56.0.15",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.11",
    "expo-navigation-bar": "~56.0.3",
    "expo-router": "~56.2.6",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-store-review": "~56.0.3",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "nativewind": "latest",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-uitextview": "^1.1.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "rn-icon-mapper": "^0.0.1",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@mr.dj2u/cli": "^0.1.24",
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.2",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
