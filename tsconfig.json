{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],

      "components/*": ["./components/*"],
      "core/*": ["./core/*"],
      "translation/*": ["./translation/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "css-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
